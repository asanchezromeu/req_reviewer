OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_EMBED_MODEL=embeddinggemma

# Hosted model credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Comma-separated API keys for the Authorization: Bearer header on /api/v1/*.
# Leave empty to disable auth (local/dev only).
API_KEYS=

# Optional persistence. Without these values the demo uses in-memory storage.
MONGO_URL=
DB_NAME=req_reviewer
CORS_ORIGINS=http://localhost:3000

# Requirement/embedding store (SQLite). Defaults to backend/data/requirements.db.
REQUIREMENTS_DB_PATH=

# Set to true/1 to use Ollama for the executive-summary endpoint instead of the
# deterministic fallback.
ENABLE_LLM_SUMMARY=
SUMMARY_TIMEOUT=12
